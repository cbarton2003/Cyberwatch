# CyberWatch API — local development environment
# Copy to .env and fill in values. Never commit .env to git.

NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cyberwatch
DB_USER=cyberwatch
DB_PASSWORD=devpassword123
DB_POOL_MAX=10
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # required in staging/prod
REDIS_TLS=false

# API Key auth (comma-separated list)
API_KEYS=dev-key-local,test-key-ci

# Alerting threshold — IOCs scoring at or above this value fire an alert (0–10)
ALERT_SCORE_THRESHOLD=7.0

# Logging
LOG_LEVEL=debug
SERVICE_NAME=cyberwatch-api
# CORS — add your GitHub Pages URL here when deploying
# e.g. ALLOWED_ORIGINS=http://localhost:8080,https://your-user.github.io
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
