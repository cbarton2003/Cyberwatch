{
  "name": "cyberwatch-api",
  "version": "1.0.0",
  "description": "CyberWatch threat intelligence REST API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --forceExit",
    "test:integration": "jest --testPathPattern=integration --forceExit",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "node-pg-migrate": "^6.2.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": { "branches": 70, "functions": 80, "lines": 80 }
    }
  }
}
